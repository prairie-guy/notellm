#!/usr/bin/env bash
set -euo pipefail

#######################################
# notellm - Jupyter + Claude Code Workspace Manager
# https://github.com/prairie-guy/notellm
#######################################

VERSION="1.0.0"
INSTALL_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/notellm"
CONFIG_FILE=".env.jupyter"
PID_FILE=".jupyter.pid"
LOG_FILE=".jupyter.log"
NOTEBOOKS_DIR="notebooks"

# Colors
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
NC=$'\033[0m'

# Default configuration
DEFAULT_PORT=9999
DEFAULT_HOST="$(hostname)"
DEFAULT_TOKEN="notellm-$(date +%s | shasum | head -c 16)"

#######################################
# Utility functions
#######################################

log_info() {
    echo -e "${GREEN}✓${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}⚠${NC} $1"
}

log_error() {
    echo -e "${RED}✗${NC} $1"
}

log_step() {
    echo -e "${BLUE}▶${NC} $1"
}

banner() {
    echo -e "${CYAN}"
    echo "╔════════════════════════════════════════════╗"
    echo "║  $1"
    echo "╚════════════════════════════════════════════╝"
    echo -e "${NC}"
}

check_port_available() {
    local port=$1
    if lsof -Pi :$port -sTCP:LISTEN -t >/dev/null 2>&1; then
        return 1
    fi
    return 0
}

is_jupyter_running() {
    if [ -f "$PID_FILE" ]; then
        local pid=$(cat "$PID_FILE")
        # Check if parent process exists
        if ps -p "$pid" > /dev/null 2>&1; then
            # Check if configured port is being listened on
            if [ -f "$CONFIG_FILE" ]; then
                source "$CONFIG_FILE"
                if lsof -Pi :${JUPYTER_PORT} -sTCP:LISTEN -t >/dev/null 2>&1; then
                    return 0
                fi
            fi
        fi
    fi
    return 1
}

# Display URLs consistently across all commands
display_urls() {
    local path_suffix="${1:-}"  # Optional path for specific notebook

    if [ "$JUPYTER_HOST" = "0.0.0.0" ]; then
        local hostname_url="${JUPYTER_HOSTNAME:-$(hostname)}"
        echo "  Remote Host: http://${hostname_url}:${JUPYTER_PORT}${path_suffix}?token=${JUPYTER_TOKEN}"
        echo "  Local Host:  http://127.0.0.1:${JUPYTER_PORT}${path_suffix}?token=${JUPYTER_TOKEN}"
    else
        echo "  URL: http://${JUPYTER_HOST}:${JUPYTER_PORT}${path_suffix}?token=${JUPYTER_TOKEN}"
    fi
}

is_process_running() {
    local pid=$1
    ps -p "$pid" > /dev/null 2>&1
}

require_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        log_error "Not a notellm project (no $CONFIG_FILE found)"
        echo ""
        echo "Run 'notellm init' first to set up this directory."
        exit 1
    fi
}

name_to_title() {
    echo "$1" | sed 's/_/ /g' | sed 's/-/ /g' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1'
}

#######################################
# Command: help
#######################################

cmd_help() {
    cat << EOF
${BOLD}notellm${NC} - Jupyter + Claude Code Workspace Manager

${YELLOW}USAGE:${NC}
    notellm <command> [options]

${YELLOW}COMMANDS:${NC}
    start [options]     Initialize (if needed) and start JupyterLab server
    stop [options]      Stop JupyterLab server
    status              Show configured server and all running Jupyter Lab instances
    clean [options]     Remove configuration files
    new <name>          Create a new notebook with boilerplate
    test                Copy test suite to notebooks/ for manual execution
    update              Update notellm to latest version
    version             Show version information
    help                Show this help message

${YELLOW}START OPTIONS:${NC}
    -t, --token TOKEN   Authentication token (default: auto-generated)
    -p, --port PORT     JupyterLab port (default: 9999)
    --host HOST         Hostname to use (default: $(hostname))
    -f, --foreground    Run server in foreground

${YELLOW}STOP OPTIONS:${NC}
    -p, --port PORT     Stop all processes on specific port

${YELLOW}CLEAN OPTIONS:${NC}
    --purge             Remove all notellm files including pyproject.toml and .notellm_template.ipynb

${YELLOW}NEW OPTIONS:${NC}
    -o, --open          Open in browser after creation

${YELLOW}EXAMPLES:${NC}
    notellm start                   # Start with defaults (auto-init if needed)
    notellm start -p 9998           # Start on port 9998
    notellm start --host myserver   # Start with custom hostname
    notellm status                  # Show server status and running instances
    notellm stop                    # Stop all processes on configured port
    notellm stop -p 8888            # Stop all processes on port 8888
    notellm clean                   # Remove config files
    notellm clean --purge           # Remove config + dependencies
    notellm new analysis            # Create analysis.ipynb in current directory
