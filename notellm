}

#######################################
# Internal: Initialize workspace
#######################################

do_init() {
    local token="$1"
    local port="$2"
    local host="$3"

    banner "Initializing notellm workspace"

    # Handle hostname binding
    # When a hostname is provided, bind to 0.0.0.0 (all interfaces) to ensure
    # accessibility both locally (via /etc/hosts) and remotely (via DNS)
    local resolved_host="$host"
    local mcp_host="$host"

    if [ "$host" != "0.0.0.0" ] && [ "$host" != "localhost" ] && ! [[ "$host" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        # It's a hostname - bind to all interfaces for maximum compatibility
        log_step "Using hostname '$host' - binding to all interfaces (0.0.0.0)"
        resolved_host="0.0.0.0"
        mcp_host="$host"
        log_info "Server will accept connections via hostname and all network interfaces"
    elif [ "$host" = "0.0.0.0" ]; then
        # User explicitly requested 0.0.0.0, use system hostname for MCP
        mcp_host="$(hostname)"
    fi
    
    # Validate port
    if ! [[ "$port" =~ ^[0-9]+$ ]] || [ "$port" -lt 1024 ] || [ "$port" -gt 65535 ]; then
        log_error "Invalid port: $port (must be 1024-65535)"
        exit 1
    fi
    
    # Check if port is available
    if ! check_port_available "$port"; then
        log_error "Port $port is already in use"
        echo ""
        echo "Try a different port: notellm start --port 9998"
        echo "Or find what's using it: lsof -i :$port"
        exit 1
    fi
    
    log_info "Port $port is available"
    
    # Check for uv
    log_step "Checking for uv..."
    if ! command -v uv &> /dev/null; then
        log_warn "uv not found. Installing..."
        curl -LsSf https://astral.sh/uv/install.sh | sh
        log_info "uv installed"
        
        if [ -f "$HOME/.local/bin/env" ]; then
            source "$HOME/.local/bin/env"
        fi
    fi
    log_info "uv found: $(uv --version)"
    
    # Copy templates
    log_step "Copying template files..."
    
    if [ ! -d "$INSTALL_DIR/templates" ]; then
        log_error "Templates not found at $INSTALL_DIR/templates"
        echo "Try: notellm update"
        exit 1
    fi
    
    cp "$INSTALL_DIR/templates/pyproject.toml" .
    cp "$INSTALL_DIR/templates/CLAUDE.md" .

    log_info "Templates copied"
    
    # Generate .env.jupyter
    log_step "Generating configuration..."
    cat > "$CONFIG_FILE" << EOF
# notellm configuration
# Generated: $(date)
JUPYTER_HOST=${resolved_host}
JUPYTER_HOSTNAME=${host}
JUPYTER_PORT=${port}
JUPYTER_TOKEN=${token}
EOF

    log_info "Created $CONFIG_FILE"

    # Generate .mcp.json using the mcp_host determined earlier
    cat > .mcp.json << EOF
{
  "mcpServers": {
    "jupyter": {
      "command": "uvx",
      "args": ["jupyter-mcp-server@latest"],
      "env": {
        "JUPYTER_URL": "http://${mcp_host}:${port}",
        "JUPYTER_TOKEN": "${token}",
        "ALLOW_IMG_OUTPUT": "true"
      }
    }
  }
}
EOF
    
    log_info "Created .mcp.json"
    
    # Update CLAUDE.md with actual values
    if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "s/{{PORT}}/${port}/g" CLAUDE.md
        sed -i '' "s/{{TOKEN}}/${token}/g" CLAUDE.md
    else
        sed -i "s/{{PORT}}/${port}/g" CLAUDE.md
        sed -i "s/{{TOKEN}}/${token}/g" CLAUDE.md
    fi
    
    log_info "Updated CLAUDE.md"
    
    # Create directory structure
    log_step "Creating directories..."
    mkdir -p notebooks data src figures
    log_info "Created notebooks/, data/, src/, figures/"
    
    # Create .gitignore
    if [ ! -f .gitignore ]; then
        log_step "Creating .gitignore..."
        cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
.venv/
.env
.env.jupyter

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints/
.jupyter.pid
.jupyter.log

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
EOF
        log_info "Created .gitignore"
    fi
    
    # Install dependencies
    log_step "Installing Python dependencies..."
    uv sync
    log_info "Dependencies installed"
    
    # Summary (minimal - full summary shown by start command)
    log_info "Workspace initialized"
}

#######################################
# Command: start
#######################################

cmd_start() {
    local foreground=false
    local token=""
    local port=""
    local host=""
    local has_init_options=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            -f|--foreground)
                foreground=true
                shift
                ;;
            -t|--token)
                token="$2"
                has_init_options=true
                shift 2
                ;;
            -p|--port)
                port="$2"
                has_init_options=true
                shift 2
                ;;
            --host)
                host="$2"
                has_init_options=true
                shift 2
                ;;
            -h|--help)
                cat << EOF
${BOLD}notellm start${NC} - Start JupyterLab server

${YELLOW}USAGE:${NC}
    notellm start [options]

${YELLOW}OPTIONS:${NC}
    -t, --token TOKEN   Authentication token (default: auto-generated)
    -p, --port PORT     Port for JupyterLab (default: 9999)
    --host HOST         Hostname to use (default: $(hostname))
    -f, --foreground    Run in foreground (default: background)
    -h, --help          Show this help

${YELLOW}BEHAVIOR:${NC}
    If options are provided OR no config exists, workspace is initialized first.
    Otherwise, uses existing configuration.

${YELLOW}EXAMPLES:${NC}
    notellm start                      # Use existing config or init with defaults
    notellm start --port 9998          # Reinitialize with port 9998
    notellm start --host myserver      # Reinitialize with hostname

EOF
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    # Check if we need to initialize
    if [ "$has_init_options" = true ] || [ ! -f "$CONFIG_FILE" ]; then
        # Set defaults if not provided
        token="${token:-$DEFAULT_TOKEN}"
        port="${port:-$DEFAULT_PORT}"
        host="${host:-$DEFAULT_HOST}"

        # Stop any running server on the target port before reinitializing
        if [ -f "$CONFIG_FILE" ]; then
            source "$CONFIG_FILE"
            if [ "$JUPYTER_PORT" != "$port" ]; then
                # Different port requested, stop old server
                if is_jupyter_running; then
                    log_step "Stopping server on port $JUPYTER_PORT..."
                    local old_pid=$(cat "$PID_FILE")
                    kill -TERM "$old_pid" 2>/dev/null || true
                    sleep 2
                    rm -f "$PID_FILE"
                fi
            fi
        fi

        # Initialize workspace
        do_init "$token" "$port" "$host"
    fi

    # Load config (now guaranteed to exist)
    source "$CONFIG_FILE"
    
    banner "Starting JupyterLab"
    
    # Check if already running
    if is_jupyter_running; then
        log_warn "JupyterLab is already running (PID: $(cat $PID_FILE))"
        echo ""
        if [ "$JUPYTER_HOST" = "0.0.0.0" ]; then
            local hostname_url="${JUPYTER_HOSTNAME:-$(hostname)}"
            echo "  Hostname: http://${hostname_url}:${JUPYTER_PORT}?token=${JUPYTER_TOKEN}"
            echo "  Network:  http://<network-ip>:${JUPYTER_PORT}?token=${JUPYTER_TOKEN}"
        else
            echo "  URL: http://${JUPYTER_HOST}:${JUPYTER_PORT}?token=${JUPYTER_TOKEN}"
        fi
        echo ""
        echo "  To stop:    notellm stop"
        exit 0
    fi
    
    # Check port
    if ! check_port_available "$JUPYTER_PORT"; then
        log_error "Port $JUPYTER_PORT is in use"
        echo ""
        echo "Find what's using it: lsof -i :$JUPYTER_PORT"
        exit 1
    fi
    
    log_info "Port $JUPYTER_PORT is available"

    if [ "$foreground" = true ]; then
        log_info "Starting in foreground (Ctrl+C to stop)..."
        echo ""
        uv run jupyter lab \
            --ip "$JUPYTER_HOST" \
            --port "$JUPYTER_PORT" \
            --port-retries=0 \
            --IdentityProvider.token="$JUPYTER_TOKEN" \
            --ServerApp.allow_remote_access=true \
            --no-browser \
            --notebook-dir=.
    else
        log_step "Starting in background..."

        nohup uv run jupyter lab \
            --ip "$JUPYTER_HOST" \
            --port "$JUPYTER_PORT" \
            --port-retries=0 \
            --IdentityProvider.token="$JUPYTER_TOKEN" \
            --ServerApp.allow_remote_access=true \
            --no-browser \
            --notebook-dir=. \
            > "$LOG_FILE" 2>&1 &
        
        echo $! > "$PID_FILE"
        sleep 2
        
        if is_jupyter_running; then
            log_info "JupyterLab started (PID: $(cat $PID_FILE))"
        else
            log_error "Failed to start. Check $LOG_FILE"
            exit 1
        fi
        
        echo ""
        echo -e "${GREEN}╔════════════════════════════════════════════════╗${NC}"
        echo -e "${GREEN}║            JupyterLab Running                  ║${NC}"
        echo -e "${GREEN}╚════════════════════════════════════════════════╝${NC}"
        echo ""

        # Display appropriate URL based on host
        if [ "$JUPYTER_HOST" = "0.0.0.0" ]; then
            local hostname_url="${JUPYTER_HOSTNAME:-$(hostname)}"
            echo -e "${YELLOW}URLs:${NC}"
            echo "  Hostname: http://${hostname_url}:${JUPYTER_PORT}?token=${JUPYTER_TOKEN}"
            echo "  Network:  http://<network-ip>:${JUPYTER_PORT}?token=${JUPYTER_TOKEN}"
        else
            echo -e "${YELLOW}URL:${NC} http://${JUPYTER_HOST}:${JUPYTER_PORT}?token=${JUPYTER_TOKEN}"
        fi

        echo ""
        echo -e "${YELLOW}Next:${NC}"
        echo -e "  ${CYAN}notellm new my_analysis${NC}   # Create notebook"
        echo -e "  ${CYAN}claude${NC}                    # Start Claude Code"
        echo -e "  ${CYAN}notellm stop${NC}              # Stop server"
        echo ""
        echo -e "${YELLOW}Logs:${NC} $LOG_FILE"
        echo ""
    fi
}

#######################################
# Command: stop
#######################################

cmd_stop() {
    local force=false
    local port=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -f|--force)
                force=true
                shift
                ;;
            -p|--port)
                port="$2"
                shift 2
                ;;
            -h|--help)
                cat << EOF
${BOLD}notellm stop${NC} - Stop JupyterLab server

${YELLOW}USAGE:${NC}
    notellm stop [options]

${YELLOW}OPTIONS:${NC}
    -p, --port PORT Port to stop server on (bypasses PID file)
    -f, --force     Force kill if graceful shutdown fails
    -h, --help      Show this help

${YELLOW}EXAMPLES:${NC}
    notellm stop              # Stop server using PID file
    notellm stop -p 9999      # Stop server on port 9999
    notellm stop --force      # Force kill if needed

EOF
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    banner "Stopping JupyterLab"

    # If port specified, stop by port instead of PID file
    if [ -n "$port" ]; then
        log_step "Stopping server on port $port..."

        if ! lsof -Pi :$port -sTCP:LISTEN -t >/dev/null 2>&1; then
            log_warn "No server running on port $port"
            exit 0
        fi

        local pid=$(lsof -Pi :$port -sTCP:LISTEN -t)
        if [ -n "$pid" ]; then
            log_info "Found process $pid on port $port"
            echo -n "  Sending SIGTERM..."
            kill -TERM "$pid" 2>/dev/null || true

            local count=0
            while is_process_running "$pid" && [ $count -lt 10 ]; do
                echo -n "."
                sleep 1
                ((count++))
            done
            echo ""

            if is_process_running "$pid"; then
                if [ "$force" = true ]; then
                    log_warn "Forcing shutdown..."
                    kill -KILL "$pid" 2>/dev/null || true
                    sleep 1
                else
                    log_error "Graceful shutdown timed out. Use --force to kill."
                    exit 1
                fi
            fi

            log_info "Server on port $port stopped"
        fi
        exit 0
    fi

    # Otherwise use PID file method (original behavior)
    if [ ! -f "$PID_FILE" ]; then
        log_warn "No PID file found. Server may not be running."

        if [ -f "$CONFIG_FILE" ]; then
            source "$CONFIG_FILE"
            if lsof -Pi :${JUPYTER_PORT:-9999} -sTCP:LISTEN -t >/dev/null 2>&1; then
                log_warn "Something is on port ${JUPYTER_PORT:-9999}"
                echo ""
                echo "To stop it: notellm stop -p ${JUPYTER_PORT:-9999}"
            fi
        fi

        exit 0
    fi
    
    local pid=$(cat "$PID_FILE")
    
    if ! is_process_running "$pid"; then
        log_warn "Process $pid not running (stale PID file)"
        rm -f "$PID_FILE"
        exit 0
    fi
    
    log_info "Found JupyterLab (PID: $pid)"
    
    echo -n "  Sending SIGTERM..."
    kill -TERM "$pid" 2>/dev/null || true
    
    local count=0
    while is_process_running "$pid" && [ $count -lt 10 ]; do
        echo -n "."
        sleep 1
        ((count++))
    done
    echo ""

    if is_process_running "$pid"; then
        if [ "$force" = true ]; then
            log_warn "Forcing shutdown..."
            kill -KILL "$pid" 2>/dev/null || true
            sleep 1

            if is_process_running "$pid"; then
                log_error "Failed to stop process $pid"
                exit 1
            fi
        else
            log_error "Graceful shutdown timed out"
            echo ""
            echo "Try: notellm stop --force"
            exit 1
        fi
    fi
    
    rm -f "$PID_FILE"
    log_info "JupyterLab stopped"

    echo ""
    echo "To restart: notellm start"
    echo ""
}

#######################################
# Command: status
#######################################

cmd_status() {
    banner "JupyterLab Status"

    # Check if local config exists
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"

        log_step "Configured Server (in current directory)"
        echo ""

        # Check if PID file exists and process is running
        if [ -f "$PID_FILE" ] && is_jupyter_running; then
            local pid=$(cat "$PID_FILE")
            log_info "Server is RUNNING (PID: $pid)"
            echo ""

            # Display URLs based on host configuration
            if [ "$JUPYTER_HOST" = "0.0.0.0" ]; then
                local hostname_url="${JUPYTER_HOSTNAME:-$(hostname)}"
                echo "  Hostname: http://${hostname_url}:${JUPYTER_PORT}?token=${JUPYTER_TOKEN}"
                echo "  Network:  http://<network-ip>:${JUPYTER_PORT}?token=${JUPYTER_TOKEN}"
            else
                echo "  URL: http://${JUPYTER_HOST}:${JUPYTER_PORT}?token=${JUPYTER_TOKEN}"
            fi
        else
            log_warn "Server is STOPPED"
            echo ""
            echo "  Port configured: ${JUPYTER_PORT}"
            echo "  Host configured: ${JUPYTER_HOST}"
        fi
        echo ""
    else
        log_warn "No configuration in current directory"
        echo ""
        echo "Run 'notellm start' to initialize and start a server"
        echo ""
    fi

    # Find all running jupyter-lab processes system-wide
    log_step "All Running Jupyter Lab Instances"
    echo ""

    # Get all jupyter-lab processes with their ports
    local jupyter_procs=$(ps aux | grep -E '[j]upyter-lab|[j]upyter lab' | grep -v grep)

    if [ -z "$jupyter_procs" ]; then
        log_info "No Jupyter Lab instances running"
    else
        # Get PIDs and find their ports
        local pids=$(echo "$jupyter_procs" | awk '{print $2}')
        local found_any=false

        for pid in $pids; do
            # Find ports this process is listening on
            local ports=$(lsof -Pan -p "$pid" -iTCP -sTCP:LISTEN 2>/dev/null | awk '{print $9}' | grep -oE '[0-9]+$' | sort -u)

            if [ -n "$ports" ]; then
                found_any=true
                local cmd=$(ps -p "$pid" -o args= | head -c 80)
                echo -e "  ${GREEN}●${NC} PID: $pid"
                echo "    Ports: $(echo $ports | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')"
                echo "    Command: $cmd..."
                echo ""
            fi
        done

        if [ "$found_any" = false ]; then
            log_warn "Found Jupyter processes but none are listening on ports"
        fi
    fi
}

#######################################
# Command: clean
#######################################

cmd_clean() {
    local purge=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --purge)
                purge=true
                shift
                ;;
            -h|--help)
                cat << EOF
${BOLD}notellm clean${NC} - Remove configuration files

${YELLOW}USAGE:${NC}
    notellm clean [options]

${YELLOW}OPTIONS:${NC}
    --purge     Also remove .venv, uv.lock, pyproject.toml, CLAUDE.md
    -h, --help  Show this help

${YELLOW}BEHAVIOR:${NC}
    Default: Removes .env.jupyter, .mcp.json, .jupyter.pid, .jupyter.log
    --purge: Also removes .venv/, uv.lock, pyproject.toml, CLAUDE.md

    User files are preserved: notebooks/, data/, src/, figures/, *.ipynb

${YELLOW}EXAMPLES:${NC}
    notellm clean           # Remove config files only
    notellm clean --purge   # Remove everything (requires confirmation)

EOF
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    banner "Cleaning workspace"

    # Check if server is running
    if [ -f "$PID_FILE" ] && is_jupyter_running; then
        log_error "Server is currently running"
        echo ""
        echo "Stop it first: notellm stop"
        exit 1
    fi

    # List what will be removed
    local files_to_remove=()

    [ -f "$CONFIG_FILE" ] && files_to_remove+=("$CONFIG_FILE")
    [ -f ".mcp.json" ] && files_to_remove+=(".mcp.json")
    [ -f "$PID_FILE" ] && files_to_remove+=("$PID_FILE")
    [ -f "$LOG_FILE" ] && files_to_remove+=("$LOG_FILE")

    if [ "$purge" = true ]; then
        [ -d ".venv" ] && files_to_remove+=(".venv/")
        [ -f "uv.lock" ] && files_to_remove+=("uv.lock")
        [ -f "pyproject.toml" ] && files_to_remove+=("pyproject.toml")
        [ -f "CLAUDE.md" ] && files_to_remove+=("CLAUDE.md")
    fi

    if [ ${#files_to_remove[@]} -eq 0 ]; then
        log_info "Nothing to clean (files already removed)"
        exit 0
    fi

    echo ""
    echo "The following will be removed:"
    for file in "${files_to_remove[@]}"; do
        echo "  - $file"
    done
    echo ""

    # Confirmation for purge
    if [ "$purge" = true ]; then
        echo -e "${YELLOW}Warning:${NC} --purge will remove dependencies (requires re-download)"
        echo -n "Continue? (y/N): "
        read -r response
        if [[ ! "$response" =~ ^[Yy]$ ]]; then
            log_warn "Clean cancelled"
            exit 0
        fi
        echo ""
    fi

    # Remove files
    log_step "Removing files..."

    for file in "${files_to_remove[@]}"; do
        if [ -d "$file" ]; then
            rm -rf "$file"
            log_info "Removed $file"
        elif [ -f "$file" ]; then
            rm -f "$file"
            log_info "Removed $file"
        fi
    done

    echo ""
    log_info "Workspace cleaned"
    echo ""
    echo "User files preserved: notebooks/, data/, src/, figures/, *.ipynb"
    echo "To reinitialize: notellm start"
    echo ""
}

#######################################
# Command: new
#######################################

cmd_new() {
    local notebook_name=""
    local notebook_dir="$NOTEBOOKS_DIR"
    local open_browser=false
    
    while [[ $# -gt 0 ]]; do
        case $1 in
            -d|--dir)
                notebook_dir="$2"
                shift 2
                ;;
            -o|--open)
                open_browser=true
                shift
                ;;
            -h|--help)
                cat << EOF
${BOLD}notellm new${NC} - Create new notebook

${YELLOW}USAGE:${NC}
    notellm new <name> [options]

${YELLOW}ARGUMENTS:${NC}
    name                Notebook name (extension ignored/replaced)

${YELLOW}OPTIONS:${NC}
    -d, --dir DIR       Directory (default: notebooks/)
    -o, --open          Open in browser after creation
    -h, --help          Show this help

${YELLOW}EXAMPLES:${NC}
    notellm new my_analysis           # notebooks/my_analysis.ipynb
    notellm new exploration -d .      # ./exploration.ipynb
    notellm new data_viz --open       # Create and open in browser

${YELLOW}NOTEBOOK INCLUDES:${NC}
    - Title (from filename)
    - Imports: polars, pandas, numpy, altair, matplotlib, seaborn
    - Configuration: display settings, paths
    - Data loading placeholder

EOF
                exit 0
                ;;
            -*)
                log_error "Unknown option: $1"
                exit 1
                ;;
            *)
                if [ -z "$notebook_name" ]; then
                    notebook_name="$1"
                else
                    log_error "Unexpected argument: $1"
                    exit 1
                fi
                shift
                ;;
        esac
    done
    
    if [ -z "$notebook_name" ]; then
        log_error "Notebook name required"
        echo ""
        echo "Usage: notellm new <name>"
        echo "       notellm new --help"
        exit 1
    fi
    
    # Clean notebook name
    local base=$(basename "$notebook_name" .ipynb)
    base=$(basename "$base" .py)
    base=$(echo "$base" | sed 's/[^a-zA-Z0-9_-]/_/g')
    
    mkdir -p "$notebook_dir"
    local path="${notebook_dir}/${base}.ipynb"
    
    if [ -f "$path" ]; then
        log_error "Notebook already exists: $path"
        exit 1
    fi
    
    local title=$(name_to_title "$base")
    local today=$(date '+%Y-%m-%d')
    
    banner "Creating notebook"
    
    cat > "$path" << EOF
{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# ${title}\\n",
    "\\n",
    "---\\n",
    "\\n",
    "Created: ${today}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Standard imports\\n",
    "import polars as pl\\n",
    "import pandas as pd\\n",
    "import numpy as np\\n",
    "\\n",
    "# Visualization\\n",
    "import altair as alt\\n",
    "import matplotlib.pyplot as plt\\n",
    "import seaborn as sns\\n",
    "\\n",
    "# Utilities\\n",
    "from pathlib import Path\\n",
    "import warnings"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Configuration\\n",
    "warnings.filterwarnings('ignore')\\n",
    "\\n",
    "# Pandas display\\n",
    "pd.set_option('display.max_columns', 100)\\n",
    "pd.set_option('display.max_rows', 100)\\n",
    "pd.set_option('display.float_format', '{:.2f}'.format)\\n",
    "\\n",
    "# Polars display\\n",
    "pl.Config.set_tbl_rows(20)\\n",
    "pl.Config.set_fmt_str_lengths(50)\\n",
    "\\n",
    "# Matplotlib\\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\\n",
    "%matplotlib inline\\n",
    "\\n",
    "# Paths\\n",
    "DATA_DIR = Path('../data')\\n",
    "FIGURES_DIR = Path('../figures')\\n",
    "\\n",
    "print('✓ Setup complete')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Data Loading"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Load your data here\\n",
    "# df = pl.read_csv(DATA_DIR / 'your_data.csv')\\n",
    "# df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Claude magic (optional)\\n",
    "# %load_ext cc_jupyter\\n",
    "# %🎷 Your prompt here"
   ]
  }
 ],
 "metadata": {
  "kernelspec": {
   "display_name": "Python 3",
   "language": "python",
   "name": "python3"
  },
  "language_info": {
   "name": "python",
   "version": "3.12"
  }
 },
 "nbformat": 4,
 "nbformat_minor": 4
}
EOF

    log_info "Created: $path"
    
    echo ""
    echo -e "${YELLOW}Contents:${NC}"
    echo "  • Title: $title"
    echo "  • Imports: polars, pandas, numpy, altair, matplotlib, seaborn"
    echo "  • Config: display options, paths"
    echo "  • Claude magic placeholder"
    echo ""
    
    # Open in browser
    if [ "$open_browser" = true ]; then
        if [ -f "$CONFIG_FILE" ]; then
            source "$CONFIG_FILE"
            if is_jupyter_running; then
                local url="http://localhost:${JUPYTER_PORT}/lab/tree/${path}?token=${JUPYTER_TOKEN}"
                log_info "Opening in browser..."
                
                if command -v xdg-open &> /dev/null; then
                    xdg-open "$url" 2>/dev/null &
                elif command -v open &> /dev/null; then
                    open "$url"
                else
                    echo "  $url"
                fi
            else
                log_warn "Server not running. Start with: notellm start"
            fi
        fi
    else
        if [ -f "$CONFIG_FILE" ] && is_jupyter_running; then
            source "$CONFIG_FILE"
            echo -e "${YELLOW}Open in JupyterLab:${NC}"
            echo "  http://localhost:${JUPYTER_PORT}/lab/tree/${path}?token=${JUPYTER_TOKEN}"
        else
            echo -e "${YELLOW}Start server:${NC} notellm start"
        fi
    fi
    
    echo ""
    echo -e "${YELLOW}In Claude Code:${NC}"
    echo "  > use the notebook $path"
    echo ""
}

#######################################
# Main
#######################################

if [[ $# -eq 0 ]]; then
    cmd_help
    exit 0
fi

command="$1"
shift

case "$command" in
    start)
        cmd_start "$@"
        ;;
    stop)
        cmd_stop "$@"
        ;;
    status)
        cmd_status
        ;;
    clean)
        cmd_clean "$@"
        ;;
    new)
        cmd_new "$@"
        ;;
    update)
        cmd_update "$@"
        ;;
    version|--version|-v)
        cmd_version
        ;;
    help|--help|-h)
        cmd_help
        ;;
    *)
        log_error "Unknown command: $command"
        echo ""
        echo "Run 'notellm help' for usage."
        exit 1
        ;;
esac
