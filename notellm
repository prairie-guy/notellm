}

#######################################
# Command: version
#######################################

cmd_version() {
    echo "notellm version $VERSION"
    echo "Install location: $INSTALL_DIR"
}

#######################################
# Command: update
#######################################

cmd_update() {
    banner "Updating notellm"

    log_warn "Manual update required"
    echo ""
    echo "To update notellm:"
    echo ""
    echo "  1. Go to your cloned repository"
    echo "  2. Pull latest changes: ${CYAN}git pull${NC}"
    echo "  3. Reinstall: ${CYAN}./setup.sh${NC}"
    echo ""
    echo "If you don't have the repository:"
    echo "  ${CYAN}git clone https://github.com/prairie-guy/notellm.git${NC}"
    echo "  ${CYAN}cd notellm && ./setup.sh${NC}"
    echo ""
}

#######################################
# Internal: Initialize workspace
#######################################

do_init() {
    local token="$1"
    local port="$2"
    local host="$3"

    banner "Initializing notellm workspace"

    # Handle hostname binding
    # When a hostname is provided, bind to 0.0.0.0 (all interfaces) to ensure
    # accessibility both locally (via /etc/hosts) and remotely (via DNS)
    local resolved_host="$host"
    local mcp_host="$host"

    if [ "$host" != "0.0.0.0" ] && [ "$host" != "localhost" ] && ! [[ "$host" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        # It's a hostname - bind to all interfaces for maximum compatibility
        log_step "Using hostname '$host' - binding to all interfaces (0.0.0.0)"
        resolved_host="0.0.0.0"
        mcp_host="$host"
        log_info "Server will accept connections via hostname and all network interfaces"
    elif [ "$host" = "0.0.0.0" ]; then
        # User explicitly requested 0.0.0.0, use system hostname for MCP
        mcp_host="$(hostname)"
    fi
    
    # Validate port
    if ! [[ "$port" =~ ^[0-9]+$ ]] || [ "$port" -lt 1024 ] || [ "$port" -gt 65535 ]; then
        log_error "Invalid port: $port (must be 1024-65535)"
        exit 1
    fi
    
    # Check if port is available
    if ! check_port_available "$port"; then
        log_error "Port $port is already in use"
        echo ""
        echo "Try a different port: notellm start --port 9998"
        echo "Or find what's using it: lsof -i :$port"
        exit 1
    fi
    
    log_info "Port $port is available"
    
    # Check for uv
    log_step "Checking for uv..."
    if ! command -v uv &> /dev/null; then
        log_warn "uv not found. Installing..."
        curl -LsSf https://astral.sh/uv/install.sh | sh
        log_info "uv installed"
        
        if [ -f "$HOME/.local/bin/env" ]; then
            source "$HOME/.local/bin/env"
        fi
    fi
    log_info "uv found: $(uv --version)"
    
    # Copy templates
    log_step "Copying template files..."

    if [ ! -d "$INSTALL_DIR/templates" ]; then
        log_error "Templates not found at $INSTALL_DIR/templates"
        echo "Try: notellm update"
        exit 1
    fi

    # Only copy pyproject.toml if it doesn't exist (preserve user customizations)
    if [ ! -f "pyproject.toml" ]; then
        cp "$INSTALL_DIR/templates/pyproject.toml" .
        log_info "Created pyproject.toml"
    else
        log_info "Preserved existing pyproject.toml (skipped template copy)"
    fi

    # Always update CLAUDE.md (contains port/token info)
    cp "$INSTALL_DIR/templates/CLAUDE.md" .
    log_info "Updated CLAUDE.md"
    
    # Generate .env.jupyter
    log_step "Generating configuration..."
    cat > "$CONFIG_FILE" << EOF
# notellm configuration
# Generated: $(date)
JUPYTER_HOST=${resolved_host}
JUPYTER_HOSTNAME=${host}
JUPYTER_PORT=${port}
JUPYTER_TOKEN=${token}
EOF

    log_info "Created $CONFIG_FILE"
    
    # Update CLAUDE.md with actual values
    if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "s/{{PORT}}/${port}/g" CLAUDE.md
        sed -i '' "s/{{TOKEN}}/${token}/g" CLAUDE.md
    else
        sed -i "s/{{PORT}}/${port}/g" CLAUDE.md
        sed -i "s/{{TOKEN}}/${token}/g" CLAUDE.md
    fi
    
    log_info "Updated CLAUDE.md"

    # Create Claude Code settings
    log_step "Creating Claude Code settings..."
    mkdir -p .claude
    cp "$INSTALL_DIR/templates/settings.json" .claude/settings.json
    cp "$INSTALL_DIR/templates/settings.json" .claude/settings.local.json
    log_info "Created .claude/settings.json and .claude/settings.local.json"

    # Copy notebook template to root as hidden file
    log_step "Copying notebook template..."
    if [ -f "$INSTALL_DIR/templates/.notellm_template.ipynb" ]; then
        cp "$INSTALL_DIR/templates/.notellm_template.ipynb" .notellm_template.ipynb
        log_info "Copied notebook template (customize: .notellm_template.ipynb)"
    fi

    # Create .gitignore (only if doesn't exist - never overwrite)
    if [ ! -f .gitignore ]; then
        log_step "Creating .gitignore..."
        if [ -f "$INSTALL_DIR/templates/.gitignore" ]; then
            cp "$INSTALL_DIR/templates/.gitignore" .gitignore
            log_info "Created .gitignore (marked for removal with clean --purge)"
        else
            log_warn ".gitignore template not found at $INSTALL_DIR/templates/"
        fi
    else
        log_info "Using existing .gitignore"
    fi
    
    # Install dependencies
    log_step "Installing Python dependencies..."
    uv sync
    log_info "Dependencies installed"
    
    # Summary (minimal - full summary shown by start command)
    log_info "Workspace initialized"
}

#######################################
# Command: start
#######################################

cmd_start() {
    local foreground=false
    local token=""
    local port=""
    local host=""
    local has_init_options=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            -f|--foreground)
                foreground=true
                shift
                ;;
            -t|--token)
                token="$2"
                has_init_options=true
                shift 2
                ;;
            -p|--port)
                port="$2"
                has_init_options=true
                shift 2
                ;;
            --host)
                host="$2"
                has_init_options=true
                shift 2
                ;;
            -h|--help)
                cat << EOF
${BOLD}notellm start${NC} - Start JupyterLab server

${YELLOW}USAGE:${NC}
    notellm start [options]

${YELLOW}OPTIONS:${NC}
    -t, --token TOKEN   Authentication token (default: auto-generated)
    -p, --port PORT     Port for JupyterLab (default: 9999)
    --host HOST         Hostname to use (default: $(hostname))
    -f, --foreground    Run in foreground (default: background)
    -h, --help          Show this help

${YELLOW}BEHAVIOR:${NC}
    If options are provided OR no config exists, workspace is initialized first.
    Otherwise, uses existing configuration.

${YELLOW}EXAMPLES:${NC}
    notellm start                      # Use existing config or init with defaults
    notellm start --port 9998          # Reinitialize with port 9998
    notellm start --host myserver      # Reinitialize with hostname

EOF
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    # Check if we need to initialize
    if [ "$has_init_options" = true ] || [ ! -f "$CONFIG_FILE" ]; then
        # Set defaults if not provided
        token="${token:-$DEFAULT_TOKEN}"
        port="${port:-$DEFAULT_PORT}"
        host="${host:-$DEFAULT_HOST}"

        # Stop any running server on the target port before reinitializing
        if [ -f "$CONFIG_FILE" ]; then
            source "$CONFIG_FILE"
            if [ "$JUPYTER_PORT" != "$port" ]; then
                # Different port requested, stop old server
                if is_jupyter_running; then
                    log_step "Stopping server on port $JUPYTER_PORT..."
                    local old_pid=$(cat "$PID_FILE")
                    kill -TERM "$old_pid" 2>/dev/null || true
                    sleep 2
                    rm -f "$PID_FILE"
                fi
            fi
        fi

        # Initialize workspace
        do_init "$token" "$port" "$host"
    fi

    # Load config (now guaranteed to exist)
    source "$CONFIG_FILE"

    # Install/update notellm_magic extension into .venv
    log_info "Installing notellm_magic extension..."
    PYTHON_VERSION=$(uv run python -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null)
    if [ -n "$PYTHON_VERSION" ]; then
        SITE_PACKAGES=".venv/lib/python${PYTHON_VERSION}/site-packages"

        if [ -d "$SITE_PACKAGES" ]; then
            # Remove old version if exists
            [ -d "$SITE_PACKAGES/notellm_magic" ] && rm -rf "$SITE_PACKAGES/notellm_magic"

            # Copy new version
            if [ -d "$INSTALL_DIR/src/notellm_magic" ]; then
                cp -r "$INSTALL_DIR/src/notellm_magic" "$SITE_PACKAGES/notellm_magic"
                log_info "notellm_magic extension installed"
            else
                log_warn "notellm_magic source not found in $INSTALL_DIR/src/"
            fi
        else
            log_warn "Could not find site-packages directory: $SITE_PACKAGES"
        fi
    else
        log_warn "Could not detect Python version for extension install"
    fi

    banner "Starting JupyterLab"
    
    # Check if already running
    if is_jupyter_running; then
        log_warn "JupyterLab is already running (PID: $(cat $PID_FILE))"
        echo ""
        display_urls
        echo ""
        echo "  To stop:    notellm stop"
        exit 0
    else
        # Clean up stale PID file if it exists
        if [ -f "$PID_FILE" ]; then
            log_warn "Cleaning up stale PID file"
            rm -f "$PID_FILE"
        fi
    fi
    
    # Check port
    if ! check_port_available "$JUPYTER_PORT"; then
        log_error "Port $JUPYTER_PORT is in use"
        echo ""
        echo "Find what's using it: lsof -i :$JUPYTER_PORT"
        exit 1
    fi
    
    log_info "Port $JUPYTER_PORT is available"

    if [ "$foreground" = true ]; then
        log_info "Starting in foreground (Ctrl+C to stop)..."
        echo ""
        # Disable RTC to prevent cell duplication bug (jupyterlab/jupyterlab#15544)
        uv run jupyter lab \
            --ip "$JUPYTER_HOST" \
            --port "$JUPYTER_PORT" \
            --port-retries=0 \
            --IdentityProvider.token="$JUPYTER_TOKEN" \
            --ServerApp.allow_remote_access=true \
            --YDocExtension.disable_rtc=True \
            --no-browser \
            --notebook-dir=.
    else
        log_step "Starting in background..."
        # Disable RTC to prevent cell duplication bug (jupyterlab/jupyterlab#15544)
        nohup uv run jupyter lab \
            --ip "$JUPYTER_HOST" \
            --port "$JUPYTER_PORT" \
            --port-retries=0 \
            --IdentityProvider.token="$JUPYTER_TOKEN" \
            --ServerApp.allow_remote_access=true \
            --YDocExtension.disable_rtc=True \
            --no-browser \
            --notebook-dir=. \
            > "$LOG_FILE" 2>&1 &
        
        echo $! > "$PID_FILE"

        # Wait for Jupyter to start listening (typically takes 2-3 seconds)
        log_info "Waiting for server to start..."
        sleep 5

        # Verify server is listening
        if ! lsof -Pi :${JUPYTER_PORT} -sTCP:LISTEN -t >/dev/null 2>&1; then
            log_error "Failed to start. Check $LOG_FILE"
            exit 1
        fi

        log_info "JupyterLab started (PID: $(cat $PID_FILE))"
        
        echo ""
        echo -e "${GREEN}╔════════════════════════════════════════════════╗${NC}"
        echo -e "${GREEN}║            JupyterLab Running                  ║${NC}"
        echo -e "${GREEN}╚════════════════════════════════════════════════╝${NC}"
        echo ""

        # Display URLs
        echo -e "${YELLOW}URLs:${NC}"
        display_urls

        echo ""
        echo -e "${YELLOW}Next:${NC}"
        echo -e "  ${CYAN}notellm new my_analysis${NC}   # Create notebook"
        echo -e "  ${CYAN}claude${NC}                    # Start Claude Code"
        echo -e "  ${CYAN}notellm stop${NC}              # Stop server"
        echo ""
        echo -e "${YELLOW}Logs:${NC} $LOG_FILE"
        echo ""

        # Apply cc_jupyter patches
        echo -e "${BLUE}Applying cc_jupyter patches...${NC}"
        if [ -f "$INSTALL_DIR/lib/patch_jupyter_magic.sh" ]; then
            if "$INSTALL_DIR/lib/patch_jupyter_magic.sh" 2>&1 | tee -a "$LOG_FILE"; then
                echo ""
            else
                PATCH_EXIT=$?
                # Check if it was just "already applied"
                if grep -q "patch(es) skipped (already applied)" "$LOG_FILE" 2>/dev/null; then
                    echo -e "${YELLOW}Patches already applied${NC}"
                    echo ""
                else
                    # Genuine failure - abort
                    echo ""
                    echo -e "${RED}╔════════════════════════════════════════════════╗${NC}"
                    echo -e "${RED}║           PATCH APPLICATION FAILED             ║${NC}"
                    echo -e "${RED}╚════════════════════════════════════════════════╝${NC}"
                    echo ""
                    echo "Server is running but cc_jupyter patches failed to apply."
                    echo "Check output above for details."
                    echo ""
                    echo "To retry manually:"
                    echo "  $INSTALL_DIR/lib/patch_jupyter_magic.sh"
                    echo ""
                    echo -e "${RED}Stopping server due to patch failure...${NC}"
                    kill $(cat "$PID_FILE") 2>/dev/null || true
                    rm -f "$PID_FILE"
                    exit 1
                fi
            fi
        else
            echo -e "${YELLOW}Patcher not found at $INSTALL_DIR/lib/ (skipping)${NC}"
            echo ""
        fi
    fi
}

#######################################
# Command: stop
#######################################

cmd_stop() {
    local port=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -p|--port)
                port="$2"
                shift 2
                ;;
            -h|--help)
                cat << EOF
${BOLD}notellm stop${NC} - Stop JupyterLab server

${YELLOW}USAGE:${NC}
    notellm stop [options]

${YELLOW}OPTIONS:${NC}
    -p, --port PORT Stop all processes on specified port
    -h, --help      Show this help

${YELLOW}BEHAVIOR:${NC}
    Stops all processes using the configured port (kills jupyter-lab servers).
    Default: Uses port from .env.jupyter, or 9999 if no config exists.

${YELLOW}EXAMPLES:${NC}
    notellm stop         # Stop server on configured port
    notellm stop -p 8888 # Stop all processes on port 8888

EOF
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    banner "Stopping JupyterLab"

    # Determine which port to use
    if [ -z "$port" ]; then
        # Try to read from config, otherwise use default
        if [ -f "$CONFIG_FILE" ]; then
            source "$CONFIG_FILE"
            port="${JUPYTER_PORT:-9999}"
        else
            port="9999"
        fi
    fi

    log_step "Stopping all processes on port $port..."

    # Get all process groups using this port (includes parent processes)
    local pids=$(ps aux | grep -E "(jupyter|uv).*--port[= ]${port}" | grep -v grep | awk '{print $2}')

    if [ -z "$pids" ]; then
        log_warn "No Jupyter processes found on port $port"
        rm -f "$PID_FILE"
        exit 0
    fi

    log_info "Found processes: $pids"

    # Send SIGTERM to all
    for pid in $pids; do
        kill -TERM "$pid" 2>/dev/null && log_info "Sent SIGTERM to PID $pid" || true
    done

    # Wait up to 8 seconds for graceful shutdown
    log_info "Waiting for graceful shutdown..."
    sleep 8

    # Force kill any survivors
    for pid in $pids; do
        if ps -p "$pid" >/dev/null 2>&1; then
            log_warn "Force killing PID $pid"
            kill -KILL "$pid" 2>/dev/null || true
        fi
    done

    sleep 1

    # Check results
    local failed=false
    for pid in $pids; do
        if ps -p "$pid" >/dev/null 2>&1; then
            log_error "Failed to kill PID $pid"
            failed=true
        fi
    done

    if [ "$failed" = false ]; then
        log_info "All processes stopped"
    fi

    # Clean up PID file
    rm -f "$PID_FILE"

    log_info "All processes on port $port stopped"
    echo ""
}

#######################################
# Command: status
#######################################

cmd_status() {
    banner "JupyterLab Status"

    # Check if local config exists
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"

        log_step "Configured Server (in current directory)"
        echo ""

        # Check if PID file exists and process is running
        if [ -f "$PID_FILE" ]; then
            if is_jupyter_running; then
                local pid=$(cat "$PID_FILE")
                log_info "Server is RUNNING (PID: $pid)"
                echo ""

                # Display URLs
                display_urls
            else
                # PID file exists but process not running or not listening - clean up
                log_warn "Server is STOPPED (cleaning up stale PID file)"
                rm -f "$PID_FILE"
                echo ""
                echo "  Port configured: ${JUPYTER_PORT}"
                echo "  Host configured: ${JUPYTER_HOST}"
            fi
        else
            log_warn "Server is STOPPED"
            echo ""
            echo "  Port configured: ${JUPYTER_PORT}"
            echo "  Host configured: ${JUPYTER_HOST}"
        fi
        echo ""
    else
        log_warn "No configuration in current directory"
        echo ""
        echo "Run 'notellm start' to initialize and start a server"
        echo ""
    fi

    # Find all running jupyter-lab processes system-wide
    log_step "All Running Jupyter Lab Instances"
    echo ""

    # Get all jupyter-lab processes with their ports
    local jupyter_procs=$(ps aux | grep -E '[j]upyter-lab|[j]upyter lab' | grep -v grep)

    if [ -z "$jupyter_procs" ]; then
        log_info "No Jupyter Lab instances running"
    else
        # Get PIDs and find their ports
        local pids=$(echo "$jupyter_procs" | awk '{print $2}')
        local found_any=false

        for pid in $pids; do
            # Find ports this process is listening on
            local ports=$(lsof -Pan -p "$pid" -iTCP -sTCP:LISTEN 2>/dev/null | awk '{print $9}' | grep -oE '[0-9]+$' | sort -u)

            if [ -n "$ports" ]; then
                found_any=true
                local cmd=$(ps -p "$pid" -o args= | head -c 80)
                echo -e "  ${GREEN}●${NC} PID: $pid"
                echo "    Ports: $(echo $ports | tr '\n' ',' | sed 's/,$//' | sed 's/,/, /g')"
                echo "    Command: $cmd..."
                echo ""
            fi
        done

        if [ "$found_any" = false ]; then
            log_warn "Found Jupyter processes but none are listening on ports"
        fi
    fi
}

#######################################
# Command: clean
#######################################

cmd_clean() {
    local purge=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --purge)
                purge=true
                shift
                ;;
            -h|--help)
                cat << EOF
${BOLD}notellm clean${NC} - Remove configuration files

${YELLOW}USAGE:${NC}
    notellm clean [options]

${YELLOW}OPTIONS:${NC}
    --purge     Remove all notellm files including user config (pyproject.toml, .notellm_template.ipynb)
    -h, --help  Show this help

${YELLOW}BEHAVIOR:${NC}
    Default: Removes .env.jupyter, .mcp.json, .jupyter.pid, .jupyter.log, .ipynb_checkpoints/
             Preserves: pyproject.toml, .notellm_template.ipynb, user notebooks

    --purge: Removes everything including .venv/, uv.lock, CLAUDE.md, .claude/,
             pyproject.toml, .notellm_template.ipynb, .gitignore (if marked), and cleans uv cache
             Preserves: User notebooks (*.ipynb except .notellm_template.ipynb)

    Note: .gitignore is only removed if it contains "### NOTELLM_GITIGNORE ###" marker

${YELLOW}EXAMPLES:${NC}
    notellm clean           # Remove config files, keep user customizations
    notellm clean --purge   # Remove everything except user notebooks

EOF
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    banner "Cleaning workspace"

    # Check if server is running
    if [ -f "$PID_FILE" ] && is_jupyter_running; then
        log_error "Server is currently running"
        echo ""
        echo "Stop it first: notellm stop"
        exit 1
    fi

    # List what will be removed
    local files_to_remove=()

    [ -f "$CONFIG_FILE" ] && files_to_remove+=("$CONFIG_FILE")
    [ -f ".mcp.json" ] && files_to_remove+=(".mcp.json")
    [ -f "$PID_FILE" ] && files_to_remove+=("$PID_FILE")
    [ -f "$LOG_FILE" ] && files_to_remove+=("$LOG_FILE")

    # Remove Jupyter checkpoint directories (auto-generated, safe to delete)
    if [ -d ".ipynb_checkpoints" ]; then
        files_to_remove+=(".ipynb_checkpoints/")
    fi
    # Also remove nested checkpoint directories
    for dir in */.ipynb_checkpoints; do
        if [ -d "$dir" ]; then
            files_to_remove+=("$dir/")
        fi
    done

    if [ "$purge" = true ]; then
        [ -d ".venv" ] && files_to_remove+=(".venv/")
        [ -f "uv.lock" ] && files_to_remove+=("uv.lock")
        [ -f "CLAUDE.md" ] && files_to_remove+=("CLAUDE.md")
        [ -d ".claude" ] && files_to_remove+=(".claude/")

        # User configuration files (only removed with --purge)
        [ -f "pyproject.toml" ] && files_to_remove+=("pyproject.toml")
        [ -f ".notellm_template.ipynb" ] && files_to_remove+=(".notellm_template.ipynb")

        # .gitignore (only if it has notellm marker)
        if [ -f ".gitignore" ] && grep -q "^### NOTELLM_GITIGNORE ###$" .gitignore; then
            files_to_remove+=(".gitignore")
        fi

        # Add all .jupyter* files and directories (except .jupyter.pid and .jupyter.log which are already included)
        for item in .jupyter*; do
            if [ -e "$item" ] && [ "$item" != "$PID_FILE" ] && [ "$item" != "$LOG_FILE" ]; then
                if [ -d "$item" ]; then
                    files_to_remove+=("$item/")
                else
                    files_to_remove+=("$item")
                fi
            fi
        done
    fi

    if [ ${#files_to_remove[@]} -eq 0 ]; then
        log_info "Nothing to clean (files already removed)"
        exit 0
    fi

    echo ""
    echo "The following will be removed:"
    for file in "${files_to_remove[@]}"; do
        echo "  - $file"
    done
    echo ""

    # Confirmation for purge
    if [ "$purge" = true ]; then
        echo -e "${YELLOW}Warning:${NC} --purge will remove all notellm files including:"
        echo "  • Dependencies (.venv/, uv.lock)"
        echo "  • User config (pyproject.toml, .notellm_template.ipynb)"
        if [ -f ".gitignore" ] && grep -q "^### NOTELLM_GITIGNORE ###$" .gitignore; then
            echo "  • .gitignore (contains notellm marker)"
        fi
        echo ""
        echo "User notebooks (*.ipynb) will be preserved."
        echo ""
        echo -n "Continue? (y/N): "
        read -r response
        if [[ ! "$response" =~ ^[Yy]$ ]]; then
            log_warn "Clean cancelled"
            exit 0
        fi
        echo ""
    fi

    # Remove files
    log_step "Removing files..."

    for file in "${files_to_remove[@]}"; do
        if [ -d "$file" ]; then
            rm -rf "$file"
            log_info "Removed $file"
        elif [ -f "$file" ]; then
            rm -f "$file"
            log_info "Removed $file"
        fi
    done

    # Clean uv cache for patched packages
    if [ "$purge" = true ]; then
        echo ""
        log_step "Cleaning uv cache for patched packages..."
        uv cache clean claude-code-jupyter-staging --force 2>/dev/null || true
        log_info "Cleaned cache for claude-code-jupyter-staging"
    fi

    echo ""
    log_info "Workspace cleaned"
    echo ""
    if [ "$purge" = true ]; then
        echo "All notellm files removed. User notebooks (*.ipynb) preserved."
    else
        echo "Config files removed. User files preserved: *.ipynb, pyproject.toml, .notellm_template.ipynb"
    fi
    echo "To reinitialize: notellm start"
    echo ""
}

#######################################
# Command: new
#######################################

cmd_new() {
    local notebook_name=""
    local open_browser=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            -o|--open)
                open_browser=true
                shift
                ;;
            -h|--help)
                cat << EOF
${BOLD}notellm new${NC} - Create new notebook

${YELLOW}USAGE:${NC}
    notellm new <name|path/name> [options]

${YELLOW}ARGUMENTS:${NC}
    name                Simple filename (created in current directory)
    path/name           File with path (creates path if doesn't exist)

${YELLOW}OPTIONS:${NC}
    -o, --open          Open in browser after creation
    -h, --help          Show this help

${YELLOW}EXAMPLES:${NC}
    notellm new analysis                    # ./analysis.ipynb
    notellm new notebooks/my_analysis       # notebooks/my_analysis.ipynb (creates notebooks/ if needed)
    notellm new data/exploration --open     # data/exploration.ipynb and open in browser

${YELLOW}NOTES:${NC}
    - Extension (.ipynb) is optional and will be added automatically
    - Creates directories as needed (never deletes existing paths)
    - Can overwrite existing files
    - Paths must be relative and within current directory (no .. or absolute paths)

${YELLOW}NOTEBOOK TEMPLATE:${NC}
    - Based on .notellm_template.ipynb (customize to change defaults)
    - Imports: polars, pandas, numpy, altair, matplotlib, seaborn
    - Configuration: pandas, polars, matplotlib settings
    - Magic commands: %cc (Claude) and notebook helpers

EOF
                exit 0
                ;;
            -*)
                log_error "Unknown option: $1"
                exit 1
                ;;
            *)
                if [ -z "$notebook_name" ]; then
                    notebook_name="$1"
                else
                    log_error "Unexpected argument: $1"
                    exit 1
                fi
                shift
                ;;
        esac
    done

    if [ -z "$notebook_name" ]; then
        log_error "Notebook name required"
        echo ""
        echo "Usage: notellm new <name|path/name>"
        echo "       notellm new --help"
        exit 1
    fi

    # Parse path and filename
    local notebook_dir
    local filename

    if [[ "$notebook_name" == */* ]]; then
        # Contains path separator
        notebook_dir=$(dirname "$notebook_name")
        filename=$(basename "$notebook_name")
    else
        # Simple filename - use current directory
        notebook_dir="."
        filename="$notebook_name"
    fi

    # Validate path is within server scope
    if [[ "$notebook_name" == /* ]]; then
        log_error "Absolute paths are not allowed"
        echo ""
        echo "JupyterLab server only has access to the current directory and subdirectories."
        echo "Use a relative path instead: notellm new notebooks/myfile"
        exit 1
    fi

    if [[ "$notebook_name" == ../* ]] || [[ "$notebook_name" == */../* ]]; then
        log_error "Paths outside the current directory are not allowed"
        echo ""
        echo "JupyterLab server only has access to the current directory and subdirectories."
        echo "Cannot create notebooks using '..' to go up directories."
        echo ""
        echo "Examples of valid paths:"
        echo "  notellm new analysis           # ./analysis.ipynb"
        echo "  notellm new notebooks/work     # ./notebooks/work.ipynb"
        exit 1
    fi

    # Clean filename
    filename=$(basename "$filename" .ipynb)
    filename=$(basename "$filename" .py)
    filename=$(echo "$filename" | sed 's/[^a-zA-Z0-9_-]/_/g')

    # Create directory if it doesn't exist
    if [ "$notebook_dir" != "." ] && [ ! -d "$notebook_dir" ]; then
        mkdir -p "$notebook_dir"
        log_info "Created directory: $notebook_dir"
    fi

    local path="${notebook_dir}/${filename}.ipynb"

    local title=$(name_to_title "$filename")
    local today=$(date '+%Y-%m-%d')

    banner "Creating notebook"

    # Use template if available
    local template_file=".notellm_template.ipynb"
    if [ -f "$template_file" ]; then
        # Copy template and replace placeholders
        sed -e "s/{{TITLE}}/$title/g" \
            -e "s/{{DATE}}/$today/g" \
            "$template_file" > "$path"
    else
        # Fallback to minimal notebook if template missing
        cat > "$path" << EOF
{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# ${title}\\n",
    "\\n",
    "---\\n",
    "\\n",
    "Created: ${today}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Standard imports\\n",
    "import polars as pl\\n",
    "import pandas as pd\\n",
    "import numpy as np\\n",
    "\\n",
    "# Visualization\\n",
    "import altair as alt\\n",
    "import matplotlib.pyplot as plt\\n",
    "import seaborn as sns\\n",
    "\\n",
    "# Utilities\\n",
    "from pathlib import Path\\n",
    "import warnings"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Configuration"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "#### Display Settings"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "warnings.filterwarnings('ignore')\\n",
    "\\n",
    "# Pandas display\\n",
    "pd.set_option('display.max_columns', 100)\\n",
    "pd.set_option('display.max_rows', 100)\\n",
    "pd.set_option('display.float_format', '{:.2f}'.format)\\n",
    "\\n",
    "# Polars display\\n",
    "pl.Config.set_tbl_rows(20)\\n",
    "pl.Config.set_fmt_str_lengths(50)\\n",
    "\\n",
    "print('✓ Display settings configured')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "#### Visualization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "plt.style.use('seaborn-v0_8-whitegrid')\\n",
    "%matplotlib inline\\n",
    "\\n",
    "print('✓ Visualization configured')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "#### Paths"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "DATA_DIR = Path('../data')\\n",
    "FIGURES_DIR = Path('../figures')\\n",
    "\\n",
    "print('✓ Paths configured')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
