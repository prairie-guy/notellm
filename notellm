  "kernelspec": {
   "display_name": "Python 3",
   "language": "python",
   "name": "python3"
  },
  "language_info": {
   "name": "python",
   "version": "3.12"
  }
 },
 "nbformat": 4,
 "nbformat_minor": 4
}
EOF
    fi

    log_info "Created: $path"
    log_info "Customize default template: .notellm_template.ipynb"
    
    echo ""
    echo -e "${YELLOW}Contents:${NC}"
    echo "  • Title: $title"
    echo "  • Imports: polars, pandas, numpy, altair, matplotlib, seaborn"
    echo "  • Configuration:"
    echo "    - Display settings"
    echo "    - Visualization"
    echo "    - Paths"
    echo "    - Jupyter magic (Claude)"
    echo ""
    
    # Open in browser
    if [ "$open_browser" = true ]; then
        if [ -f "$CONFIG_FILE" ]; then
            source "$CONFIG_FILE"
            if is_jupyter_running; then
                local url="http://127.0.0.1:${JUPYTER_PORT}/lab/tree/${path}?token=${JUPYTER_TOKEN}"
                log_info "Opening in browser..."

                if command -v xdg-open &> /dev/null; then
                    xdg-open "$url" 2>/dev/null &
                elif command -v open &> /dev/null; then
                    open "$url"
                else
                    echo "  $url"
                fi
            else
                log_warn "Server not running. Start with: notellm start"
            fi
        fi
    else
        if [ -f "$CONFIG_FILE" ] && is_jupyter_running; then
            source "$CONFIG_FILE"
            echo -e "${YELLOW}Open in JupyterLab:${NC}"
            display_urls "/lab/tree/${path}"
        else
            echo -e "${YELLOW}Start server:${NC} notellm start"
        fi
    fi
    
    echo ""
    echo -e "${YELLOW}In Claude Code:${NC}"
    echo "  > use the notebook $path"
    echo ""
}

#######################################
# Command: test
#######################################

cmd_test() {
    banner "notellm Test Suite"

    # Copy template to current directory
    local dest="TestSuite.ipynb"

    if [ ! -d "$INSTALL_DIR/templates" ]; then
        log_error "Templates not found at $INSTALL_DIR/templates"
        echo "Try: notellm update"
        exit 1
    fi

    if [ ! -f "$INSTALL_DIR/templates/TestSuite.ipynb" ]; then
        log_error "TestSuite.ipynb template not found"
        echo "Expected: $INSTALL_DIR/templates/TestSuite.ipynb"
        exit 1
    fi

    cp "$INSTALL_DIR/templates/TestSuite.ipynb" "$dest"

    echo ""
    log_info "Test suite copied successfully"
    echo ""
    echo -e "${YELLOW}Next steps:${NC}"

    # Show URL if server is running
    if [ -f "$CONFIG_FILE" ] && is_jupyter_running; then
        source "$CONFIG_FILE"
        echo "  1. Open JupyterLab:"
        echo ""
        display_urls "/lab"
    else
        echo "  1. Start server: notellm start"
    fi

    echo "  2. Open TestSuite.ipynb"
    echo "  3. Execute cells sequentially"
    echo "  4. Review test results at the end of the notebook"
    echo ""
    echo -e "${BLUE}Note:${NC} Claude integration tests (%cc, %%cc, %%nb_modify) will"
    echo "      create new cells dynamically. Execute generated cells manually"
    echo "      to verify the code works correctly."
    echo ""
}

#######################################
# Main
#######################################

if [[ $# -eq 0 ]]; then
    cmd_help
    exit 0
fi

command="$1"
shift

case "$command" in
    start)
        cmd_start "$@"
        ;;
    stop)
        cmd_stop "$@"
        ;;
    status)
        cmd_status
        ;;
    clean)
        cmd_clean "$@"
        ;;
    new)
        cmd_new "$@"
        ;;
    test)
        cmd_test "$@"
        ;;
    update)
        cmd_update "$@"
        ;;
    version|--version|-v)
        cmd_version
        ;;
    help|--help|-h)
        cmd_help
        ;;
    *)
        log_error "Unknown command: $command"
        echo ""
        echo "Run 'notellm help' for usage."
        exit 1
        ;;
esac
