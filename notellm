#######################################
# Command: version
#######################################

cmd_version() {
    echo "notellm version $VERSION"
    echo "Install location: $INSTALL_DIR"
}

#######################################
# Command: update
#######################################

cmd_update() {
    banner "Updating notellm"

    log_warn "Manual update required"
    echo ""
    echo "To update notellm:"
    echo ""
    echo "  1. Go to your cloned repository"
    echo "  2. Pull latest changes: ${CYAN}git pull${NC}"
    echo "  3. Reinstall: ${CYAN}./setup.sh${NC}"
    echo ""
    echo "If you don't have the repository:"
    echo "  ${CYAN}git clone https://github.com/prairie-guy/notellm.git${NC}"
    echo "  ${CYAN}cd notellm && ./setup.sh${NC}"
