    notellm test                    # Copy TestSuite.ipynb to current directory

${YELLOW}WORKFLOW:${NC}
    1. cd ~/my-project
    2. notellm start                # Automatically sets everything up
    3. notellm new analysis         # Create a notebook
    4. Open JupyterLab URL (shown above) on one side
    5. Run 'claude' in terminal on other side
    6. notellm stop (when done)

